ADD COLUMN tag TEXT;</sql><sql name="SQL 12*">UPDATE products
SET tag='Best Seller'
WHERE id=1;

UPDATE products
SET tag='Trending'
WHERE id=2;

UPDATE products
SET tag='New Drop'
WHERE id=3;</sql><sql name="SQL 13*">SELECT * FROM products;
DELETE FROM products
WHERE id NOT IN (

    SELECT MIN(id)
    FROM products
    GROUP BY
        name,
        price,
        description,
        image

);

